    {
      "id": "parse_verify",
      "position": { "x": 460, "y": 720 },
      "data": {
        "kind": "Processor",
        "varName": "parse_verify",
        "llmMode": false,
        "mode": "sample",
        "fnSource": "def parse_and_verify(row):\n    \"\"\"Pull each model's \\\\boxed{} answer out of its CoT, compare to the\n    reference numerically, count agreement. Empty sol_x extracts to '' and\n    counts as wrong. Also flips `synthetic` to True since the row now\n    carries AI-generated content (China AIGC labeling compliance).\"\"\"\n    from verifier import extract_boxed_or_number, numeric_equal\n    ans = {k: extract_boxed_or_number(row[f\"sol_{k}\"]) for k in \"abc\"}\n    correct = {k: numeric_equal(ans[k], row[\"reference_answer\"]) for k in \"abc\"}\n    return {\n        **row,\n        \"ans_a\": ans[\"a\"], \"ans_b\": ans[\"b\"], \"ans_c\": ans[\"c\"],\n        \"correct_a\": correct[\"a\"], \"correct_b\": correct[\"b\"], \"correct_c\": correct[\"c\"],\n        \"num_correct\": sum(correct.values()),\n        \"synthetic\": True,\n    }\n",
        "fnName": "parse_and_verify",
        "llmPrompt": "",
        "llmOutputField": "",
        "llmClient": { "mode": "modelRef", "modelNodeId": "" },
        "llmGenKwargs": "{}",
        "intraBatchWorkers": 1,
        "inputSchema": [
