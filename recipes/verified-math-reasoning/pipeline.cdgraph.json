    {
      "id": "join",
      "position": { "x": 460, "y": 580 },
      "data": {
        "kind": "Processor",
        "varName": "join_sols",
        "llmMode": false,
        "mode": "batch",
        "fnSource": "def join_by_id(batch):\n    \"\"\"JoinById: fan-in merger. Stateful — collects partial rows from the\n    three upstream gens by row['id']; emits when 3 contributions arrived\n    (regardless of content — empty sol_x flows through, verifier handles).\n\n    In v1.0.6 of cargodash this is a built-in operator (`from cargodash\n    import JoinById; join = JoinById(key='id', expected=3, ...)`); this\n    inlined version is the equivalent for WebUI projects that haven't\n    been upgraded yet.\"\"\"\n    import threading\n    from cargodash import Batch\n    if not hasattr(join_by_id, \"_buf\"):\n        join_by_id._buf = {}\n        join_by_id._lock = threading.Lock()\n    required = (\"sol_a\", \"sol_b\", \"sol_c\")\n    ready = []\n    with join_by_id._lock:\n        for row in batch.rows:\n            entry = join_by_id._buf.setdefault(\n                row[\"id\"], {\"slot\": dict(row), \"count\": 0}\n            )\n            for f in required:\n                if row.get(f):\n                    entry[\"slot\"][f] = row[f]\n            entry[\"count\"] += 1\n            if entry[\"count\"] >= 3:\n                ready.append(entry[\"slot\"])\n                del join_by_id._buf[row[\"id\"]]\n    if not ready:\n        return None\n    return Batch(rows=ready, schema=batch.schema)\n",
        "fnName": "join_by_id",
        "llmPrompt": "",
        "llmOutputField": "",
        "llmClient": { "mode": "modelRef", "modelNodeId": "" },
        "llmGenKwargs": "{}",
        "intraBatchWorkers": 1,
        "inputSchema": [
          { "name": "id", "type": "str" },
          { "name": "source", "type": "str" },
          { "name": "problem", "type": "str" },
          { "name": "reference_answer", "type": "str" },
          { "name": "sol_a", "type": "str" },
          { "name": "sol_b", "type": "str" },
